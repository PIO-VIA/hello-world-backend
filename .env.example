# App Settings
PROJECT_NAME="School Newspaper API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security
JWT_SECRET_KEY=yoursecretkeyhere
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=school_newspaper
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/school_newspaper

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@school.com

# External services
FIREBASE_CREDENTIALS_PATH=
